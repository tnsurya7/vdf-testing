# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
    
# Gmail SMTP credentials (use an App Password, not your account password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# App base URL (used in email links)
VDF_APP_BASE_URL=http://localhost:5173

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/vdf
SPRING_DATASOURCE_USERNAME=your-db-username
SPRING_DATASOURCE_PASSWORD=your-db-password

# JWT
VDF_JWT_SECRET=a-string-secret-at-least-256-bits-long-change-this-in-production

# ─────────────────────────────────────────────────────────────────────────────
# WINDOWS SETUP INSTRUCTIONS
# ─────────────────────────────────────────────────────────────────────────────
# 1. Set PostgreSQL user password (run once in psql or pgAdmin):
#       ALTER USER suryakumar WITH PASSWORD '1234';
#
# 2. On Windows PowerShell, set env vars and run the backend:
#       $env:SPRING_DATASOURCE_URL="jdbc:postgresql://localhost:5432/vdf"
#       $env:SPRING_DATASOURCE_USERNAME="your-db-username"
#       $env:SPRING_DATASOURCE_PASSWORD="your-db-password"
